// Serveur de salons TEMPO — Cloudflare Worker + Durable Object.
// Déploiement : `npx wrangler login` puis `npx wrangler deploy` (voir docs/DEPLOYMENT.md).
{
  "name": "tempo-rooms",
  "main": "src/index.ts",
  "compatibility_date": "2026-01-01",
  "durable_objects": {
    "bindings": [{ "name": "ROOMS", "class_name": "TempoRoom" }]
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["TempoRoom"] }]
}
